<div class="card mx-auto shadow-lg" {{ attributes.defaults(stimulus_controller('travel')) }}>
    <div class="card-header p-2">
        {{ ux_icon('travel') }}
        <strong class="ms-1 pt-1 d-inline-block">Travel Planner Bot</strong>
        <button {{ live_action('reset') }} class="btn btn-sm btn-outline-secondary float-end">{{ ux_icon('cancel') }} Reset Chat</button>
    </div>
    <div id="chat-body" class="card-body p-4 overflow-auto">
        {% if this.itinerary %}
            {% set itinerary = this.itinerary %}
            <div data-loading="hide">
                <h2 class="mb-4 pb-3 border-bottom text-primary d-flex align-items-center">
                    {{ ux_icon('mdi:map-marker', { class: 'me-2 text-danger', height: '32px', width: '32px' }) }}
                    {{ itinerary.destination }}
                </h2>
                
                <div class="p-3 bg-light rounded-4 mb-4 border-start border-primary border-4 shadow-sm">
                    <p class="mb-0 fs-5 text-secondary italic">"{{ itinerary.description }}"</p>
                </div>

                <div class="row mb-4 g-3">
                    <div class="col-md-4">
                        <div class="info-box p-3 bg-primary bg-opacity-10 rounded-4 text-center border h-100">
                            {{ ux_icon('mdi:calendar-clock', { height: '32px', width: '32px', class: 'text-primary mb-2' }) }}
                            <p class="mb-0 small">
                                <span class="text-muted d-block uppercase tracking-wider">Duration</span>
                                <strong class="fs-5 text-dark">{{ itinerary.durationInDays }} Days</strong>
                            </p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-box p-3 bg-success bg-opacity-10 rounded-4 text-center border h-100">
                            {{ ux_icon('mdi:cash-multiple', { height: '32px', width: '32px', class: 'text-success mb-2' }) }}
                            <p class="mb-0 small">
                                <span class="text-muted d-block">Budget Class</span>
                                <strong class="fs-5 text-dark">{{ itinerary.budget }}</strong>
                            </p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-box p-3 bg-warning bg-opacity-10 rounded-4 text-center border h-100">
                            {{ ux_icon('mdi:star-face', { height: '32px', width: '32px', class: 'text-warning mb-2' }) }}
                            <p class="mb-0 small">
                                <span class="text-muted d-block">Key Highlight</span>
                                <strong class="fs-6 text-dark d-block text-truncate" title="{{ itinerary.highlights|first }}">
                                    {{ itinerary.highlights|first }}
                                </strong>
                            </p>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <!-- Highlights Section -->
                    <div class="col-md-12 mb-4 text-start">
                        <h5 class="mb-3 d-flex align-items-center">
                            {{ ux_icon('mdi:compass-outline', { class: 'me-2 text-primary' }) }}
                            Trip Highlights
                        </h5>
                        <div class="d-flex flex-wrap gap-2">
                            {% for highlight in itinerary.highlights %}
                                <span class="badge text-start bg-primary bg-opacity-75 text-white py-2 px-3 rounded-pill">
                                    {{ highlight }}
                                </span>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <!-- Daily Itinerary -->
                <div class="col-md-12 text-start mt-2">
                    <h5 class="mb-4 d-flex align-items-center">
                        {{ ux_icon('mdi:map', { class: 'me-2 text-primary' }) }}
                        Day-by-Day Plan
                    </h5>
                    
                    <div class="position-relative ps-2">
                        {% for day in itinerary.days %}
                            <div class="mb-5 position-relative">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-primary text-white rounded-4 d-flex align-items-center justify-content-center me-3 shadow-sm" style="min-width: 48px; width: 48px; height: 48px;">
                                        <span class="fw-bold fs-5">D{{ day.dayNumber }}</span>
                                    </div>
                                    <div>
                                        <h5 class="mb-0 text-dark">{{ day.theme }}</h5>
                                        <small class="text-muted">Day {{ day.dayNumber }} itinerary</small>
                                    </div>
                                </div>
                                
                                <div class="ms-5 ps-2 border-start border-2 border-primary border-opacity-25">
                                    {% for activity in day.activities %}
                                        <div class="p-3 mb-3 bg-white border rounded-4 shadow-sm position-relative">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <span class="badge rounded-pill {% if activity.time == 'Morning' %}bg-warning text-dark{% elseif activity.time == 'Afternoon' %}bg-info text-dark{% else %}bg-dark text-white{% endif %}">
                                                    {{ activity.time }}
                                                </span>
                                                <span class="text-muted small">
                                                    {{ ux_icon('mdi:wallet-giftcard', { class: 'me-1', height: '14px', width: '14px' }) }}
                                                    {{ activity.cost }}
                                                </span>
                                            </div>
                                            <p class="mb-0 text-secondary">{{ activity.description }}</p>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% else %}
            <div data-loading="hide" class="text-center mt-5 py-5 bg-white rounded-5 shadow-sm w-75 mx-auto">
                {{ ux_icon('travel', { height: '200px', width: '200px', class: 'text-primary' }) }}
                <h4 class="mt-5">Travel Planner</h4>
                <span class="text-muted">Describe your dream vacation (destination, duration, and budget class) to generate a structured itinerary.</span>
                <p class="text-muted small mt-2">Example: "A 3-day budget trip to Rome exploring historic sites" or "A 5-day luxury getaway in Bali"</p>
            </div>
        {% endif %}
        <div id="loading-message" data-loading>
            <div class="d-flex flex-column align-items-center justify-content-center w-100">
                <div class="spinner-border text-primary mb-4" style="width: 60px; height: 60px;">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <h4 class="text-muted mb-2">Our bot is planning your dream getaway...</h4>
                <p class="text-secondary small">Generating structured itinerary with Gemini...</p>
            </div>
        </div>
    </div>
    <div class="card-footer p-2">
        <form class="input-group" {{ live_action('submit:prevent') }}>
            <input autofocus id="chat-message"
                   data-model="norender|message"
                   type="text" class="form-control border-0" placeholder="Where do you want to travel? ...">
            <button class="btn btn-outline-secondary border-0">
                {{ ux_icon('send') }} Submit
            </button>
        </form>
    </div>
</div>
